# Block all web access to the storage directory.
# Primary protection is keeping this folder OUTSIDE the web root
# (document root = /public). This is a safety net for shared hosting
# where everything sits under one public folder.

# Apache 2.4+
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Apache 2.2
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
