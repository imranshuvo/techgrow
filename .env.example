# TechGrow Ltd — environment configuration.
#
# Copy to ".env" for local development:   cp .env.example .env
# On Coolify / a server, set these as real environment variables instead.
# Real environment variables always take precedence over the .env file.

# Application environment: "production" (errors hidden) or "local" (errors shown).
APP_ENV=local

# Admin dashboard password — store the BCRYPT HASH, never the plain password.
# Generate one with:   php bin/hash-password.php
# Leave empty to disable the admin dashboard entirely.
ADMIN_PASSWORD_HASH=

# Trust the X-Forwarded-For header to record the real client IP.
# Set to "true" when running behind a reverse proxy (Coolify, Nginx, Cloudflare).
# Keep "false" for direct/local serving so the IP cannot be spoofed.
TRUST_PROXY=false

# Admin session idle timeout, in seconds (default 2 hours).
ADMIN_SESSION_IDLE=7200

# Rows per page in the admin subscriber table.
ADMIN_PAGE_SIZE=25
